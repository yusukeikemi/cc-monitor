{
  // launch.json の preLaunchTask "npm: compile" の実体。F5 前に必ず src→out を作り直す。
  // watch は開発中に保存ごと自動コンパイルしたいとき用（手動で実行）。
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "compile",
      "label": "npm: compile",
      "group": "build",
      "problemMatcher": ["$tsc"]
    },
    {
      "type": "npm",
      "script": "watch",
      "label": "npm: watch",
      "group": "build",
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"]
    }
  ]
}
